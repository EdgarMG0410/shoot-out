{
  "$schema": "https://design-tokens.org",
  "brand": "FORMA",
  "color": {
    "pitch":      { "value": "#00E676", "role": "Primary accent — action only (join/confirm/go)" },
    "pitchHover": { "value": "#00C853", "role": "Primary button hover/active" },
    "pitchInk":   { "value": "#08140C", "role": "Text/icon on green" },
    "pitchDeep":  { "value": "#00A152", "role": "Green text on light backgrounds" },
    "ink":        { "value": "#1F2020", "role": "Logo black / primary text on light" },
    "carbon":     { "value": "#0E0F0F", "role": "Dark canvas" },
    "steel":      { "value": "#8E8F90", "role": "Logo grey" },
    "slate":      { "value": "#565858", "role": "Muted text" },
    "mist":       { "value": "#E3E4E0", "role": "Light borders/dividers" },
    "paper":      { "value": "#F4F5F2", "role": "Light canvas" },
    "white":      { "value": "#FFFFFF" }
  },
  "theme": {
    "dark":  { "bg": "#0E0F0F", "surface": "#181919", "border": "rgba(255,255,255,0.10)", "text": "#FFFFFF", "textMute": "#A4A6A4" },
    "light": { "bg": "#F4F5F2", "surface": "#FFFFFF", "border": "#E3E4E0", "text": "#1F2020", "textMute": "#565858" }
  },
  "font": {
    "display": { "family": "Space Grotesk", "use": "Headlines, scores, team names" },
    "body":    { "family": "Manrope", "use": "UI and body text" },
    "mono":    { "family": "Space Mono", "use": "Labels, kit numbers, stats" }
  },
  "typeScale": {
    "display": { "size": 76, "weight": 700, "tracking": "-0.03em", "lineHeight": 0.92 },
    "h1":      { "size": 46, "weight": 700, "tracking": "-0.03em" },
    "h2":      { "size": 28, "weight": 600 },
    "h3":      { "size": 22, "weight": 600 },
    "body":    { "size": 15, "weight": 400, "lineHeight": 1.6 },
    "caption": { "size": 12, "weight": 500 },
    "mono":    { "size": 12, "weight": 700, "tracking": "0.14em", "transform": "uppercase" }
  },
  "radius": { "sm": 8, "md": 11, "lg": 14, "xl": 18, "pill": 999 },
  "shadow": { "card": "0 12px 40px rgba(0,0,0,0.12)", "phone": "0 20px 50px rgba(0,0,0,0.40)" },
  "spacing": { "base": 4, "scale": [4, 8, 12, 16, 20, 24, 32, 48, 56] }
}
