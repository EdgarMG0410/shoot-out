TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=info
APP_KEY=
NODE_ENV=development
SESSION_DRIVER=cookie

# Database driver: 'mysql' (local) or 'postgres' (Render / managed)
DB_CONNECTION=mysql

# MySQL — point these at your local database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=shootout

# Postgres / managed hosts provide a single connection string instead of DB_*.
# DB_CONNECTION=postgres
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Supabase Storage — image uploads (logos, fotos). Create a PUBLIC bucket.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_KEY=<service_role key — server-side only>
# SUPABASE_BUCKET=uploads